AI_SERVICE_PORT=8000
BACKEND_URL=http://localhost:5000

# Gemini-backed Candidate Identification (app/services/gemini_client.py).
# Leave GEMINI_API_KEY unset to run in fallback mode -- the service still
# returns a full result (derived from the Confidence Engine ranking),
# just without an LLM-generated explanation.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SECONDS=20
